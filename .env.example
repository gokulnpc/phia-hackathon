# Root reference only — each app loads its own env (never commit real `.env` files).
#
# Web:        apps/web/.env.local       → NEXT_PUBLIC_* (see apps/web/.env.local.example)
# Extension: apps/extension-wxt/.env     → VITE_*       (see apps/extension-wxt/.env.example)
# Backend:    apps/backend/.env         → SUPABASE_*, DATABASE_URL, FASHN_API_KEY (see apps/backend/.env.example)
#
