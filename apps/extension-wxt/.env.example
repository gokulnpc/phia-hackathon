# Same Supabase project as apps/backend SUPABASE_URL (Bearer calls to the API use this session).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Mirror FastAPI base URL — no trailing slash. Production builds must match the Railway **mirror-api**
# HTTP service public URL (the host that serves GET /health), not worker-only services.
VITE_MIRROR_API_URL=http://localhost:8000
# Optional: web app origin for “Create account”, OAuth handoff, Terms/Privacy links (no trailing slash)
# VITE_MIRROR_WEB_URL=http://localhost:3000
