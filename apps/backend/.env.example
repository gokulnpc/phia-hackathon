# Copy to .env — never commit real values.
#
# SUPABASE_URL must match the SAME project as apps/web NEXT_PUBLIC_SUPABASE_URL and
# apps/extension-wxt VITE_SUPABASE_URL (e.g. https://<project-ref>.supabase.co).
#
# SUPABASE_JWT_SECRET: Dashboard → JWT Keys → "Legacy JWT secret (still used)" (Reveal), or
# Settings → API → JWT Secret on older dashboards. NOT anon, NOT service_role, NOT sbp_ CLI.
# Required when Supabase issues HS256 access tokens. Wrong value → 401 on protected routes.
#
# If your project uses JWT Signing Keys (asymmetric access tokens: ES256, RS256, …), the API
# verifies via JWKS at {SUPABASE_URL}/auth/v1/.well-known/jwks.json — SUPABASE_URL must be set;
# SUPABASE_JWT_SECRET is unused for those tokens. You can keep both set during transitions.
#
# DATABASE_URL: Postgres connection for try-on worker (SKIP LOCKED). Local: supabase status → DB URL.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_ANON_KEY=
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
# Fash AI — Virtual Try-On v1.6 (direct API). Job mode: fast→performance, standard→balanced, quality→quality.
FASHN_API_KEY=
# Google AI Studio / Gemini API — required for avatar_generation_jobs worker (reference preprocessing).
# Image generation must be enabled on a billed project; free-tier-only keys often fail image calls.
GEMINI_API_KEY=
# Example: gemini-2.5-flash-image — use the current image-generation model id from Google’s docs.
GEMINI_AVATAR_MODEL=
# Optional: editorial polish after FASHN try-on (same IMAGE modality as avatar). If unset, worker uses GEMINI_AVATAR_MODEL when TRYON_EDITORIAL_ENABLED=true.
# GEMINI_TRYON_EDITORIAL_MODEL=
# TRYON_EDITORIAL_ENABLED=false
# Closet enrichment — Gemini vision model that extracts structured attributes from closet items.
# Example: gemini-2.5-flash (text+vision → JSON). Required by mirror-closet-enrichment-worker.
GEMINI_ATTRIBUTES_MODEL=
# Fit score — Gemini text+vision model producing structured wardrobe-fit JSON.
# Example: gemini-2.5-flash. Required by mirror-fit-score-worker.
GEMINI_FIT_SCORE_MODEL=
# Reverse search ("Worn by") — external visual-search provider.
# - mock: deterministic fixtures (no network).
# - serpapi: Google Lens only.
# - composite: Apify Pinterest + Apify Instagram hashtags + Google Lens (Zara-tuned queries).
VISUAL_SEARCH_PROVIDER=mock
# SerpAPI key (Google Lens). Required for serpapi or composite.
SERPAPI_API_KEY=
# Apify token — Pinterest search actor + Instagram hashtag actor (composite only).
APIFY_API_TOKEN=
# If worker logs show HTTP 403 on run-sync-get-dataset-items for Pinterest, the default
# store actor is not enabled for this token — subscribe to it in Apify Console or set
# APIFY_PINTEREST_ACTOR_ID to an actor your account can run.
#   - Default: scraperforge~pinterest-search-scraper  (free tier + request-per-query)
#   - Paid alternative: epctex/pinterest-scraper       (higher volume, $35/mo trial)
# Both input shapes are handled automatically via substring detection in
# apify_pinterest.py::_build_search_payload — no code change needed to switch.
# APIFY_PINTEREST_ACTOR_ID=scraperforge~pinterest-search-scraper
# APIFY_PINTEREST_ACTOR_ID=epctex/pinterest-scraper
# APIFY_INSTAGRAM_ACTOR_ID=apify~instagram-hashtag-scraper
# Per-child HTTP timeout inside composite (seconds).
# VISUAL_SEARCH_COMPOSITE_PER_PROVIDER_TIMEOUT_S=25
# Gemini person-detection model for reverse-search post-filter (drops flatlays / logos).
# Example: gemini-2.5-flash. NOT an image-generation model.
GEMINI_PERSON_FILTER_MODEL=
API_HOST=0.0.0.0
# Listen port. Local dev: API_PORT. Railway injects PORT; PORT wins if both are set.
# Do not set API_PORT=8000 in Railway (common mistake) or health checks will fail.
API_PORT=8000
